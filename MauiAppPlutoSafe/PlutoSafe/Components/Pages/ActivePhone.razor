@* @page "/" *@
@page "/active-phone"
@inject NavigationManager Nav
@inject UserSession Session
@inject HttpClient Http 

<link href="css/user-details.css" rel="stylesheet" />

<div class="ap-page">

    <div class="ap-header">
        <span class="back" @onclick='() => Nav.NavigateTo("/dashboard")'>&larr;</span>
        <h3>Active Phone</h3>
    </div>

    <div class="search-box">
    <input type="text"
           placeholder="@Placeholder"
           value="@Value"
           @oninput="OnInput" />
    </div>
   @if (users == null)
    {
        <p style="padding:16px;">Loading...</p>
    }
    else if (users.Count == 0)
    {
        <p style="padding:16px;">No activation phones found.</p>
    }
    else
    {
        foreach (var user in users)
        {
            <UserActivationCard EnableNavigation="true"
                    UserName="@user.userName"
                    RegNo="@user.loanAccountNumber"
                    Imei1="@user.serialNumber"
                    Phone="@user.alternateMobile"
                    ShowLockActions="true" />
        }
    }
</div>
@code {
    [Parameter] public string Placeholder { get; set; } = "Search ..";
    [Parameter] public string Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private List<ActiveUser> users = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadActiveUsers();
    }

    async Task LoadActiveUsers()
    {
        try
        {
            var dealerId = Session.DealerProfileId;

            if (string.IsNullOrEmpty(dealerId))
                return;

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Session.Token);

            var response = await Http.GetFromJsonAsync<ActiveUsersResponse>(
                $"https://devmobileapi.plutosafe.in/api/IOSDashboardDevicesList/active-users?dealerId={dealerId}&pageNumber=1&pageSize=10");

            if (response != null && response.data?.data != null)
            {
                users = response.data.data
                    .Select(x => new ActiveUser
                    {
                        userName = x.customer.name,
                        loanAccountNumber = x.customer.loanAccountNumber,
                        alternateMobile = x.customer.alternateMobile,
                        serialNumber = x.customer.serialNumber
                    })
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        await ValueChanged.InvokeAsync(e.Value?.ToString());
    }

    @* public class ActiveUsersResponse
    {
        public bool isSuccess { get; set; }
        public List<ActiveUser> data { get; set; }
        public string message { get; set; }
    } *@


    public class ActiveUser
    {
        public string userName { get; set; }
        public string loanAccountNumber { get; set; }
        public string alternateMobile { get; set; }
        public string serialNumber { get; set; }
    }
    public class ActiveUsersResponse
    {
        public bool isSuccess { get; set; }
        public ActiveUsersData data { get; set; }
    }

    public class ActiveUsersData
    {
        public int totalRecords { get; set; }
        public int pageNumber { get; set; }
        public int pageSize { get; set; }
        public List<ActiveUserItem> data { get; set; }
    }
    public class ActiveUserItem
    {
        public Customer customer { get; set; }
        public AppSecurity appSecurity { get; set; }
    }
    public class Customer
    {
        public string name { get; set; }
        public string loanAccountNumber { get; set; }
        public string alternateMobile { get; set; }
        public string serialNumber { get; set; }
    }


    public class AppSecurity
    {
        public bool isActivation { get; set; }
    }

}
<style> 
.search-box {
  padding-left: 12px;
  padding-right: 12px;
}
.search-box input {
  width: 100%;
  height: 54px;
  padding: 0 16px;
  border-radius: 14px;
  background: transparent;        /* remove background */
  border: 1px solid #F0F0F3;      /* outline color */
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: #000;
  outline: none;
}
</style>
<style>
.ap-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
}

.ap-header h3 {
  margin: 0;
  font-size: 20px;
}
.ap-page {
  padding-bottom: 16px;
}
</style>